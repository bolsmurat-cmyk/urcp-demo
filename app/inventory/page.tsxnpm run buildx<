'use client'
import { useState, useMemo, Suspense } from 'react'
import { useRouter, useSearchParams } from 'next/navigation'
import AppShell from '@/components/AppShell'
import { PRODUCTS, INVENTORY, ORGS, getOrg, getWarehouse } from '@/lib/mockData'
import { Search, SlidersHorizontal, X, ChevronRight } from 'lucide-react'

function InventoryContent() {
  const router = useRouter()
  const params = useSearchParams()
  const [query, setQuery]       = useState(params.get('q') ?? '')
  const [orgFilter, setOrgFilter] = useState('all')

  const results = useMemo(() => {
    const q = query.toLowerCase()
    return PRODUCTS.filter(p =>
      (!q || p.name.toLowerCase().includes(q) || p.code.toLowerCase().includes(q) || p.category.toLowerCase().includes(q))
      && p.status === 'Approved'
    ).map(p => {
      const inv = INVENTORY.filter(i => i.product_id === p.id && (orgFilter === 'all' || i.org_id === orgFilter))
      const totalQty   = inv.reduce((s,i) => s + i.qty, 0)
      const totalXfer  = inv.reduce((s,i) => s + Math.max(0, i.qty - i.reserved), 0)
      const totalValue = inv.reduce((s,i) => s + i.qty * i.avg_cost, 0)
      return { ...p, inv, totalQty, totalXfer, totalValue }
    }).filter(p => p.totalQty > 0)
  }, [query, orgFilter])

  return (
    <div>
      {/* Header */}
      <div style={{ background: '#fff', padding: '12px 14px 14px', borderBottom: '0.5px solid rgba(0,0,0,0.07)', position: 'sticky', top: 0, zIndex: 10 }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 10 }}>
          <div style={{ flex: 1, display: 'flex', alignItems: 'center', gap: 8, background: '#F4F6F5', border: `1px solid ${query ? '#0F6E56' : 'rgba(0,0,0,0.1)'}`, borderRadius: 10, padding: '0 12px', height: 42 }}>
            <Search size={16} color={query ? '#0F6E56' : '#aaa'} />
            <input value={query} onChange={e => setQuery(e.target.value)} placeholder="Search products, codes…"
              style={{ flex: 1, background: 'none', border: 'none', outline: 'none', fontSize: 15, color: '#1a1a1a' }} />
            {query && <button onClick={() => setQuery('')} style={{ background: 'none', border: 'none', cursor: 'pointer', padding: 2, display: 'flex' }}><X size={14} color="#aaa" /></button>}
          </div>
          <button style={{ width: 42, height: 42, background: '#F4F6F5', border: '0.5px solid rgba(0,0,0,0.1)', borderRadius: 10, display: 'flex', alignItems: 'center', justifyContent: 'center', cursor: 'pointer' }}>
            <SlidersHorizontal size={18} color="#555" />
          </button>
        </div>
        {/* Org pills */}
        <div style={{ display: 'flex', gap: 6, overflowX: 'auto', paddingBottom: 2 }}>
          {[{ id: 'all', name: 'All orgs' }, ...ORGS].map(o => (
            <button key={o.id} onClick={() => setOrgFilter(o.id)}
              style={{ fontSize: 12, padding: '4px 12px', borderRadius: 20, border: '0.5px solid rgba(0,0,0,0.1)', whiteSpace: 'nowrap', background: orgFilter === o.id ? '#0F6E56' : '#fff', color: orgFilter === o.id ? '#fff' : '#555', cursor: 'pointer', flexShrink: 0 }}>
              {o.name}
            </button>
          ))}
        </div>
      </div>

      <div style={{ padding: 14 }} className="animate-in">
        <div style={{ fontSize: 12, color: '#999', marginBottom: 10 }}>
          {results.length} product{results.length !== 1 ? 's' : ''} · {results.reduce((s,r) => s + r.totalQty, 0)} total units
        </div>

        {results.map(prod => (
          <div key={prod.id} style={{ background: '#fff', borderRadius: 14, border: '0.5px solid rgba(0,0,0,0.08)', marginBottom: 10, overflow: 'hidden' }}>
            {/* Product header */}
            <button onClick={() => router.push(`/inventory/${prod.id}`)}
              style={{ width: '100%', display: 'flex', alignItems: 'center', gap: 10, padding: '12px 14px', background: 'none', border: 'none', cursor: 'pointer', textAlign: 'left', borderBottom: '0.5px solid rgba(0,0,0,0.06)' }}>
              <div style={{ width: 40, height: 40, borderRadius: 10, background: '#E1F5EE', display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0 }}>
                <Search size={18} color="#0F6E56" />
              </div>
              <div style={{ flex: 1, minWidth: 0 }}>
                <div style={{ fontSize: 14, fontWeight: 500, color: '#1a1a1a' }}>{prod.name}</div>
                <div style={{ fontSize: 11, color: '#999' }}>{prod.code} · {prod.category} · {prod.unit}</div>
              </div>
              <div style={{ textAlign: 'right', flexShrink: 0 }}>
                <span className="badge badge-ok" style={{ marginBottom: 4, display: 'block' }}>Available</span>
                <span style={{ fontSize: 11, color: '#999' }}>{prod.criticality}</span>
              </div>
            </button>

            {/* Column labels */}
            <div style={{ display: 'flex', padding: '5px 14px 3px', gap: 0 }}>
              <div style={{ flex: 1, fontSize: 10, color: '#bbb', fontWeight: 500, textTransform: 'uppercase', letterSpacing: '0.04em' }}>Org / Warehouse</div>
              <div style={{ fontSize: 10, color: '#bbb', fontWeight: 500, textTransform: 'uppercase', letterSpacing: '0.04em', minWidth: 48, textAlign: 'right', marginRight: 8 }}>Qty</div>
              <div style={{ fontSize: 10, color: '#bbb', fontWeight: 500, textTransform: 'uppercase', letterSpacing: '0.04em', minWidth: 72, textAlign: 'right' }}>Transferable</div>
            </div>

            {/* Org rows */}
            {prod.inv.map((row, idx) => {
              const org = getOrg(row.org_id)!
              const wh  = getWarehouse(row.warehouse_id)!
              const xfer = Math.max(0, row.qty - row.reserved)
              return (
                <div key={row.id} style={{ display: 'flex', alignItems: 'center', padding: '8px 14px', borderTop: '0.5px solid rgba(0,0,0,0.05)', gap: 8 }}>
                  <div style={{ width: 8, height: 8, borderRadius: '50%', background: org.color, flexShrink: 0 }} />
                  <div style={{ flex: 1, minWidth: 0 }}>
                    <div style={{ fontSize: 13, fontWeight: 500, color: '#1a1a1a' }}>{org.name}</div>
                    <div style={{ fontSize: 11, color: '#999' }}>{wh.name} · {row.location}</div>
                  </div>
                  <div style={{ textAlign: 'right', minWidth: 48, marginRight: 8 }}>
                    <div style={{ fontSize: 13, fontWeight: 500, color: row.qty <= 10 ? '#E24B4A' : '#1a1a1a' }}>{row.qty}</div>
                    <div style={{ fontSize: 10, color: '#bbb' }}>{{'units'}row.unit ?? 'units'}</div>
                  </div>
                  <div style={{ minWidth: 72, textAlign: 'right' }}>
                    {xfer > 0
                      ? <span style={{ fontSize: 11, fontWeight: 500, padding: '2px 7px', borderRadius: 4, background: '#E6F1FB', color: '#0C447C', display: 'inline-block' }}>{xfer} avail.</span>
                      : <span style={{ fontSize: 11, padding: '2px 7px', borderRadius: 4, background: '#F1EFE8', color: '#999', display: 'inline-block' }}>0 avail.</span>
                    }
                  </div>
                </div>
              )
            })}

            {/* Totals */}
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', padding: '9px 14px', background: '#F9FAF9', borderTop: '0.5px solid rgba(0,0,0,0.06)' }}>
              <span style={{ fontSize: 12, color: '#999' }}>Total · ${prod.totalValue.toLocaleString('en', { maximumFractionDigits: 0 })} value</span>
              <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                <span style={{ fontSize: 13, fontWeight: 500, color: '#1a1a1a' }}>{prod.totalQty} units</span>
                <span style={{ fontSize: 11, fontWeight: 500, padding: '2px 7px', borderRadius: 4, background: '#E6F1FB', color: '#0C447C' }}>{prod.totalXfer} transferable</span>
              </div>
            </div>

            {/* Action row */}
            <div style={{ display: 'flex', gap: 0, borderTop: '0.5px solid rgba(0,0,0,0.06)' }}>
              <button onClick={() => router.push(`/inventory/${prod.id}`)}
                style={{ flex: 1, padding: '10px 0', background: 'none', border: 'none', borderRight: '0.5px solid rgba(0,0,0,0.06)', cursor: 'pointer', fontSize: 13, color: '#555', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 4 }}>
                View detail <ChevronRight size={14} />
              </button>
              <button onClick={() => router.push(`/transfer?product=${prod.id}`)}
                style={{ flex: 1, padding: '10px 0', background: 'none', border: 'none', cursor: 'pointer', fontSize: 13, fontWeight: 500, color: '#0F6E56', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 4 }}>
                Transfer ›
              </button>
            </div>
          </div>
        ))}

        {results.length === 0 && (
          <div style={{ textAlign: 'center', padding: '48px 0', color: '#bbb' }}>
            <Search size={36} color="#ddd" style={{ margin: '0 auto 12px', display: 'block' }} />
            <div style={{ fontSize: 15, fontWeight: 500, color: '#999' }}>No products found</div>
            <div style={{ fontSize: 13, marginTop: 4 }}>Try a different search term</div>
          </div>
        )}
      </div>
    </div>
  )
}

export default function InventoryPage() {
  return (
    <AppShell>
      <Suspense fallback={<div style={{ padding: 24, textAlign: 'center', color: '#999' }}>Loading…</div>}>
        <InventoryContent />
      </Suspense>
    </AppShell>
  )
}
